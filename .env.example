# Sao chép file này thành .env rồi điền giá trị thật
# Lấy Gemini API key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Tạo bot Telegram qua @BotFather để lấy token
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# (Tùy chọn) Giới hạn chỉ user_id này được dùng bot. Để trống = cho phép tất cả.
ALLOWED_USER_ID=""
