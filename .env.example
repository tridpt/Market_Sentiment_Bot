# Sao chép file này thành .env rồi điền giá trị thật
# Lấy Gemini API key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Tạo bot Telegram qua @BotFather để lấy token
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# (Tùy chọn) Giới hạn chỉ user_id này được dùng bot. Để trống = cho phép tất cả.
ALLOWED_USER_ID=""

# ===== NGUỒN DỮ LIỆU TÙY CHỌN (để trống thì tự bỏ qua) =====

# YouTube Data API v3 - cào bình luận video.
# Lấy key tại: https://console.cloud.google.com/apis/credentials (bật "YouTube Data API v3")
YOUTUBE_API_KEY=""

# Reddit OAuth (app-only) - cào bài đăng.
# Tạo app dạng "script" tại: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USER_AGENT="python:sentiment_bot:v1.0 (by /u/your_username)"
